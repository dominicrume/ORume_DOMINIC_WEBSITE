# ═══════════════════════════════════════════════════════════════
# LIVING ENGINE — Environment Configuration
# H2: Copy → .env · NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════

# ── AI BRAIN ─────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── SERPAPI — Legal Google Search + Maps ──────────────────────
# https://serpapi.com/manage-api-key · $50/mo = 5,000 searches
SERPAPI_KEY=your-serpapi-key-here

# ── HUNTER.IO — Email verification + discovery ────────────────
# https://hunter.io/api-keys · $49/mo Starter
HUNTER_API_KEY=your-hunter-key-here

# ── APOLLO.IO — B2B contact enrichment ───────────────────────
# https://app.apollo.io/#/settings/integrations/api · Free/paid
APOLLO_API_KEY=your-apollo-key-here

# ── KEEPA — Licensed Amazon BSR data ─────────────────────────
# https://keepa.com/#!api · €19/mo
KEEPA_API_KEY=your-keepa-key-here

# ── COMPANIES HOUSE — UK business registry (FREE) ────────────
# https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_KEY=your-ch-key-here

# ── INSTANTLY.AI — Email send + automation ───────────────────
# https://app.instantly.ai/app/settings/integrations · $37/mo
INSTANTLY_API_KEY=your-instantly-key-here
INSTANTLY_CAMPAIGN_ID=your-campaign-id-here

# ── DATABASE ─────────────────────────────────────────────────
DB_PATH=./data/living-engine.db
MEMORY_PATH=./memory

# ── AGENT SCHEDULE ───────────────────────────────────────────
# Cron: run full cycle every Monday + Thursday at 6am
AGENT_CRON=0 6 * * 1,4
# Run learn-only cycle every day at 8pm
LEARN_CRON=0 20 * * *
AGENT_TIMEZONE=Europe/London

# ── ELASTIC — ship winston logs to Elasticsearch ─────────────
# Endpoint + API key from your Elastic deployment. Leave blank to
# disable shipping (console + logs/*.log keep working regardless).
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_DATASET=rumedominic.growth-brain

# ── PIPELINE LIMITS ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
MAX_DOMAINS_PER_CYCLE=200
MAX_LEADS_TO_ENRICH=100
MAX_LEADS_TO_SCORE=200
MAX_OUTREACH_PER_CYCLE=30
MIN_SCORE_FOR_OUTREACH=65

# Rate limits (req/min)
SERPAPI_RPM=8
HUNTER_RPM=25
APOLLO_RPM=15
KEEPA_RPM=4

# ── MX TARGETING ─────────────────────────────────────────────
MX_TARGETS=networksolutions,privateemail,titan.email,zoho,emailsrvr,messagingengine,secureserver,ionos,protonmail,siteground,krystal,123-reg,hushmail

# ── SENDING IDENTITY ─────────────────────────────────────────
SENDING_NAME=Alex
SENDING_EMAIL=alex@yourdomain.com
REPLY_TO=alex@yourdomain.com

# ── RUME'S BOOK FUNNEL ───────────────────────────────────────
BOOK_OPTIN_URL=https://vorem.co/free
BOOK_AUTHOR_NAME=Rume Dominic
BOOK_BRAND=Vorem Nigeria
