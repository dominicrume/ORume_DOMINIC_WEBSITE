{
  "name": "rumedominic-site",
  "version": "1.0.0",
  "private": true,
  "description": "Flagship personal brand + lead-gen site for Rume Dominic (rumedominic.com)",
  "scripts": {
    "dev": "next dev -p 4010",
    "build": "next build",
    "start": "next start -p 4010",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
