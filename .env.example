# ---------------------------------------------------------------------------
# rumedominic.com — environment variables (TEMPLATE ONLY — no real secrets here)
# Copy to `.env.local` for dev, and set the same keys in Vercel Project Settings.
# NEVER commit real secrets. Server-only keys have NO NEXT_PUBLIC_ prefix.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://rumedominic.com

# Calendly scheduling link for "Book a Strategy Call" (client-side embed).
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/your-event

# Instant-access resources shown on /access after signup (optional overrides).
NEXT_PUBLIC_BOOK_URL=
NEXT_PUBLIC_COURSE_URL=

# --- Supabase (server-side lead store) -------------------------------------
# Authoritative store for contact + newsletter leads. The publishable key can
# INSERT but not read (RLS), so it's safe server-side. Read leads in the dashboard.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_publishable_key

# --- Brevo (server-side only — email/CRM sync) -----------------------------
# Secret API key, used only in app/api/* route handlers. Get it in Brevo settings.
BREVO_API_KEY=your_brevo_api_key
# Numeric Brevo list IDs (JUST the number, e.g. 5 — NOT "#5").
BREVO_CONTACT_LIST_ID=5
BREVO_NEWSLETTER_LIST_ID=5

# Optional: notification sender/recipient for lead alerts.
BREVO_SENDER_EMAIL=hello@rumedominic.com
BREVO_NOTIFY_EMAIL=dominicrume@gmail.com
